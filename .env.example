# ImTakt Server — contributors / self-host only (adoption uses api.imtakt.dev)
PORT=3011
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=dev-master-key
MEILI_INDEX=stops
MOTIS_URL=http://localhost:8080
# Override hosted API when running local stack (MCP/CLI pick this up)
# IMTAKT_SERVER_URL=http://localhost:3011
FEED_MANIFEST_PATH=../imtakt-gtfs/apps/feeds/data/de_full/.feed-manifest.json
DATABASE_URL=postgres://imtakt:imtakt-dev@localhost:5432/imtakt
FEED_MAX_AGE_HOURS=48
IMTAKT_SEMANTIC_RERANK=1
# Production tuning (optional)
# NODE_ENV=production
# BUN_REUSE_PORT=1
# HEALTH_CACHE_SEC=10
# FEED_CACHE_SEC=30
# STOP_SEARCH_CACHE_SEC=60
# PLACE_RESOLVE_CACHE_SEC=300
# RATE_LIMIT_RPM=120
# WARM_INTERVAL_SEC=300
# MEILI_TIMEOUT_MS=8000
# ROUTER_TIMEOUT_MS=30000
# IMTAKT_ARCHIVE=1
