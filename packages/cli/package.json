{
  "name": "@imtakt/cli",
  "version": "0.3.2",
  "description": "Agent-oriented CLI for German transit — JSON for pipes/agents, markdown on TTY",
  "license": "MIT",
  "homepage": "https://imtakt.dev/cli",
  "keywords": [
    "gtfs",
    "transit",
    "germany",
    "imtakt",
    "cli",
    "bahn"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "analytics",
    "README.md"
  ],
  "bin": {
    "imtakt": "./dist/main.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImTakt/imtakt.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "dev": "bun run src/main.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@imtakt/core": "^0.3.2",
    "@imtakt/sdk": "^0.3.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
