{
  "name": "@imtakt/cli",
  "version": "0.1.0",
  "description": "Agent-oriented CLI for German transit via ImTakt Server (JSON stdout)",
  "license": "MIT",
  "homepage": "https://imtakt.dev/cli",
  "keywords": ["gtfs", "transit", "germany", "imtakt", "cli", "bahn"],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "imtakt": "./dist/main.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImTakt/imtakt.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "dev": "bun run src/main.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@imtakt/core": "^0.1.0",
    "@imtakt/sdk": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
