{
  "name": "@imtakt/mcp",
  "version": "0.2.0",
  "description": "MCP server — five tools for German transit intelligence (resolve, plan, board, live, train run)",
  "license": "MIT",
  "homepage": "https://imtakt.dev/mcp",
  "keywords": ["mcp", "model-context-protocol", "gtfs", "transit", "germany", "imtakt", "cursor", "claude"],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "imtakt-mcp": "./dist/main.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImTakt/imtakt.git",
    "directory": "mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "bun test src/",
    "dev": "bun run src/main.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@imtakt/core": "^0.2.0",
    "@imtakt/sdk": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
