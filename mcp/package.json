{
  "name": "@imtakt/mcp",
  "version": "0.3.2",
  "description": "MCP server — five verbs for German transit (find, plan, show, status, follow)",
  "license": "MIT",
  "homepage": "https://imtakt.dev/mcp",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gtfs",
    "transit",
    "germany",
    "imtakt",
    "cursor",
    "claude"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "imtakt-mcp": "./dist/main.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImTakt/imtakt.git",
    "directory": "mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "bun run src/main.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@imtakt/core": "^0.3.2",
    "@imtakt/sdk": "^0.3.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
